APP_NAME=CitiInfo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# API server (api.citiinfo.com.au): allow frontend origins for CORS
# CORS_ALLOWED_ORIGINS=https://citiinfo.com.au,https://www.citiinfo.com.au

# Local: use file driver. Production (https://crm.citiinfo.com.au): see bottom of file.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false

# --- Production example (Hostinger: crm.citiinfo.com.au) ---
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://crm.citiinfo.com.au
# SESSION_DRIVER=file
# SESSION_DOMAIN=
# SESSION_SECURE_COOKIE=true
# Do NOT set SESSION_DOMAIN=localhost on production.

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=citiinfo
DB_USERNAME=root
DB_PASSWORD=
